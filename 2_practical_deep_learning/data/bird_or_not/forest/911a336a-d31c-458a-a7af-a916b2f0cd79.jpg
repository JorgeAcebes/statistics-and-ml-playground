<body class="home wp-singular page-template-default page page-id-8 wp-custom-logo wp-embed-responsive wp-theme-hello-elementor hello-elementor-default elementor-default elementor-kit-7 elementor-page elementor-page-8">


<a class="skip-link screen-reader-text" href="#content">Skip to content</a>

		<header data-elementor-type="header" data-elementor-id="14" class="elementor elementor-14 elementor-location-header" data-elementor-post-type="elementor_library">
			<div class="elementor-element elementor-element-f563e72 e-con-full e-flex e-con e-parent" data-id="f563e72" data-element_type="container" data-e-type="container">
				<div class="elementor-element elementor-element-122d708 elementor-widget elementor-widget-html" data-id="122d708" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
					<style>
  .ufa236-full-header {
    --black: #050505;
    --header-top: #28292e;
    --header-mid: #1d1e23;
    --header-bottom: #111214;
    --orange: #ffad42;
    --orange-light: #ffd08a;
    --orange-mid: #ffbd62;
    --orange-dark: #f28a18;
    --gold: #d6a93c;
    --gold-light: #ffe08a;
    --silver-light: #ffffff;
    --silver-mid: #d9d9d9;
    --silver-dark: #8f8f8f;
    --text: #ffffff;
    --dark-text: #050505;
    --frame: #0f0f0e;
    --border: rgba(255, 208, 120, 0.34);

    position: relative;
    z-index: 9999;
    width: 100%;
    overflow: hidden;
    background: var(--black);
    color: var(--text);
    border-top: 1px solid var(--gold);
    border-bottom: 1px solid var(--border);
    font-family: inherit;
  }

  .ufa236-full-header,
  .ufa236-full-header * {
    box-sizing: border-box;
  }

  .ufa236-full-header a {
    color: inherit;
    text-decoration: none;
  }

  .ufa236-top-layer {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0)),
      linear-gradient(180deg, var(--header-top) 0%, var(--header-mid) 46%, var(--header-bottom) 100%);
  }

  .ufa236-top-inner,
  .ufa236-nav-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-left: clamp(12px, 2.5vw, 28px);
    padding-right: clamp(12px, 2.5vw, 28px);
  }

  .ufa236-top-inner {
    padding-top: 7px;
    padding-bottom: 10px;
  }

  .ufa236-ticker {
    overflow: hidden;
    margin-bottom: 8px;
    border: 1px solid rgba(255, 224, 138, 0.2);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(255, 224, 138, 0.07), rgba(255, 224, 138, 0.015)),
      rgba(0, 0, 0, 0.2);
  }

  .ufa236-ticker__track {
    display: flex;
    width: max-content;
    padding: 6px 0;
    animation: ufa236TickerMove 28s linear infinite;
  }

  .ufa236-ticker:hover .ufa236-ticker__track {
    animation-play-state: paused;
  }

  .ufa236-ticker__text {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding-right: 42px;
    color: var(--gold-light);
    font-size: clamp(11px, 0.95vw, 13px);
    font-weight: 700;
    white-space: nowrap;
  }

  .ufa236-ticker__text::before {
    content: "★";
    color: var(--gold);
  }

  .ufa236-hero {
    display: grid;
    grid-template-columns: minmax(170px, 1fr) auto minmax(170px, 1fr);
    align-items: center;
    gap: clamp(12px, 2.5vw, 28px);
    min-height: clamp(108px, 12vw, 165px);
  }

  .ufa236-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    text-align: center;
  }

  .ufa236-brand__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ufa236-brand__logo {
    display: block;
    width: clamp(190px, 27vw, 340px);
    max-width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 4px 14px rgba(214, 169, 60, 0.22));
    animation: ufa236BrandFloat 3.4s ease-in-out infinite;
  }

  .ufa236-brand__tagline {
    margin: 0;
    color: #eeeeee;
    font-size: clamp(11px, 1.1vw, 15px);
    font-weight: 600;
    letter-spacing: 0.18em;
    line-height: 1.25;
    text-transform: uppercase;
    opacity: 0.88;
  }

  .ufa236-hero-action {
    display: flex;
    align-items: center;
  }

  .ufa236-hero-action--left {
    justify-content: flex-start;
  }

  .ufa236-hero-action--right {
    justify-content: flex-end;
  }

  .ufa236-cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: min(100%, 250px);
    min-height: 56px;
    padding: 10px 16px;
    border-radius: 12px;
    border: 2px solid rgba(255, 255, 255, 0.68);
    color: var(--dark-text);
    background: linear-gradient(180deg, var(--silver-light) 0%, var(--silver-mid) 52%, var(--silver-dark) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.72),
      inset 0 -2px 0 rgba(0, 0, 0, 0.16);
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .ufa236-cta--register {
    color: var(--dark-text);
    border-color: rgba(255, 240, 170, 0.86);
    background: linear-gradient(180deg, #fff4bd 0%, #f0c94d 48%, #c99622 100%);
  }

  .ufa236-cta::before {
    content: "";
    position: absolute;
    inset: -2px -50%;
    z-index: 0;
    background: linear-gradient(
      120deg,
      transparent 35%,
      rgba(255, 255, 255, 0.38) 50%,
      transparent 65%
    );
    transform: translateX(-120%);
    animation: ufa236CtaShine 3.8s ease-in-out infinite;
    pointer-events: none;
  }

  .ufa236-cta:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
  }

  .ufa236-cta__icon,
  .ufa236-cta__text {
    position: relative;
    z-index: 1;
  }

  .ufa236-cta__icon {
    width: 30px;
    height: 30px;
    flex: 0 0 auto;
    color: #000000;
  }

  .ufa236-cta__text {
    display: block;
    text-align: left;
  }

  .ufa236-cta__title {
    display: block;
    color: #000000;
    font-size: clamp(17px, 1.5vw, 23px);
    font-weight: 900;
    line-height: 1.15;
    white-space: nowrap;
  }

  .ufa236-cta__desc {
    display: block;
    margin-top: 1px;
    color: #111111;
    font-size: 11px;
    font-weight: 700;
    line-height: 1.25;
    opacity: 0.82;
    white-space: nowrap;
  }

  .ufa236-nav-check {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  .ufa236-nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: calc(100% - 24px);
    min-height: 46px;
    margin: 0 auto;
    padding: 0 16px;
    border: 1px solid var(--frame);
    border-radius: 12px;
    background: var(--frame);
    color: var(--gold-light);
    font-weight: 900;
    cursor: pointer;
  }

  .ufa236-nav-toggle__bars {
    position: relative;
    width: 22px;
    height: 16px;
    flex: 0 0 auto;
  }

  .ufa236-nav-toggle__bars span {
    position: absolute;
    left: 0;
    width: 22px;
    height: 2px;
    border-radius: 99px;
    background: currentColor;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .ufa236-nav-toggle__bars span:nth-child(1) { top: 0; }
  .ufa236-nav-toggle__bars span:nth-child(2) { top: 7px; }
  .ufa236-nav-toggle__bars span:nth-child(3) { top: 14px; }

  .ufa236-nav-check:checked ~ .ufa236-nav-toggle .ufa236-nav-toggle__bars span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .ufa236-nav-check:checked ~ .ufa236-nav-toggle .ufa236-nav-toggle__bars span:nth-child(2) {
    opacity: 0;
  }

  .ufa236-nav-check:checked ~ .ufa236-nav-toggle .ufa236-nav-toggle__bars span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .ufa236-bottom-layer {
    background: linear-gradient(180deg, var(--orange-light) 0%, var(--orange-mid) 42%, var(--orange) 72%, var(--orange-dark) 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.28);
  }

  .ufa236-nav-inner {
    padding-top: 6px;
    padding-bottom: 6px;
  }

  .ufa236-main-nav {
    border: 1px solid var(--frame);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.16);
    overflow: hidden;
  }

  .ufa236-main-nav__list {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ufa236-main-nav__list li {
    min-width: 0;
    margin: 0;
    padding: 0;
  }

  .ufa236-main-nav__link,
  .ufa236-main-nav__link:visited,
  .ufa236-main-nav__link:hover,
  .ufa236-main-nav__link:focus,
  .ufa236-main-nav__link:active,
  .ufa236-main-nav__link .ufa236-main-nav__icon,
  .ufa236-main-nav__link .ufa236-main-nav__label {
    color: #000000;
  }

  .ufa236-main-nav__link {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    min-height: 58px;
    padding: 8px 7px;
    border-right: 1px solid var(--frame);
    text-align: center;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .ufa236-main-nav__list li:last-child .ufa236-main-nav__link {
    border-right: 0;
  }

  .ufa236-main-nav__link:hover {
    background: rgba(15, 15, 14, 0.1);
    transform: translateY(-1px);
  }

  .ufa236-main-nav__link[aria-current="page"],
  .ufa236-main-nav__link[aria-current="page"] .ufa236-main-nav__icon,
  .ufa236-main-nav__link[aria-current="page"] .ufa236-main-nav__label {
    color: var(--gold-light);
  }

  .ufa236-main-nav__link[aria-current="page"] {
    background: var(--frame);
    transform: none;
  }

  .ufa236-main-nav__icon {
    width: 23px;
    height: 23px;
    color: currentColor;
  }

  .ufa236-main-nav__label {
    display: block;
    color: currentColor;
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 900;
    line-height: 1.2;
    white-space: nowrap;
  }

  @keyframes ufa236TickerMove {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @keyframes ufa236CtaShine {
    0%, 42% {
      opacity: 0;
      transform: translateX(-120%);
    }

    52% {
      opacity: 1;
    }

    72%, 100% {
      opacity: 0;
      transform: translateX(120%);
    }
  }

  @keyframes ufa236BrandFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  @media (max-width: 1024px) {
    .ufa236-top-inner {
      padding-top: 8px;
      padding-bottom: 10px;
    }

    .ufa236-ticker {
      margin-bottom: 10px;
      border-radius: 12px;
    }

    .ufa236-hero {
      grid-template-columns: 1fr;
      gap: 10px;
      min-height: auto;
    }

    .ufa236-brand {
      order: 1;
      padding: 6px 0;
    }

    .ufa236-hero-action--left { order: 2; }
    .ufa236-hero-action--right { order: 3; }

    .ufa236-hero-action {
      justify-content: center;
      width: 100%;
    }

    .ufa236-cta {
      width: 100%;
      max-width: 520px;
      min-height: 54px;
      border-radius: 12px;
    }

    .ufa236-bottom-layer {
      padding-top: 8px;
      padding-bottom: 8px;
    }

    .ufa236-nav-toggle {
      display: flex;
    }

    .ufa236-main-nav {
      display: none;
      margin-top: 8px;
      border-radius: 12px;
    }

    .ufa236-nav-check:checked ~ .ufa236-main-nav {
      display: block;
    }

    .ufa236-main-nav__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ufa236-main-nav__list li:last-child:nth-child(odd) {
      grid-column: 1 / -1;
    }

    .ufa236-main-nav__link {
      min-height: 56px;
      border-right: 1px solid var(--frame);
      border-bottom: 1px solid var(--frame);
    }

    .ufa236-main-nav__list li:nth-child(2n) .ufa236-main-nav__link {
      border-right: 0;
    }

    .ufa236-main-nav__list li:last-child .ufa236-main-nav__link {
      border-right: 0;
      border-bottom: 0;
    }
  }

  @media (max-width: 520px) {
    .ufa236-brand__logo {
      width: 200px;
    }

    .ufa236-brand__tagline {
      font-size: 10.5px;
      letter-spacing: 0.12em;
    }

    .ufa236-cta {
      min-height: 52px;
      padding: 9px 14px;
    }

    .ufa236-cta__title {
      font-size: 17px;
    }

    .ufa236-cta__desc {
      font-size: 10.5px;
    }

    .ufa236-main-nav__list {
      grid-template-columns: 1fr;
    }

    .ufa236-main-nav__list li:last-child:nth-child(odd) {
      grid-column: auto;
    }

