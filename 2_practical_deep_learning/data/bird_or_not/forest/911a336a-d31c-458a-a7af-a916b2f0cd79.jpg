					<style>
  .ufa236-footer {
    --dark: #050505;
    --dark-soft: #111111;
    --dark-panel: #18191d;
    --orange: #ffad42;
    --orange-light: #ffd08a;
    --orange-mid: #ffbd62;
    --orange-dark: #f28a18;
    --text-dark: #050505;
    --text-light: #ffffff;
    --muted: #c9cbd3;
    --border-dark: rgba(0, 0, 0, 0.22);
    --border-light: rgba(255, 173, 66, 0.32);

    width: 100%;
    background: var(--dark);
    font-family: inherit;
  }

  .ufa236-footer,
  .ufa236-footer * {
    box-sizing: border-box;
  }

  .ufa236-footer a {
    color: inherit;
    text-decoration: none;
  }

  /* TOP ORANGE SOCIAL BAR */
  .ufa236-footer__social-bar {
    padding: 18px clamp(16px, 4vw, 72px);
    background: linear-gradient(
      180deg,
      var(--orange-light) 0%,
      var(--orange-mid) 42%,
      var(--orange) 72%,
      var(--orange-dark) 100%
    );
    color: var(--text-dark);
    border-top: 1px solid rgba(255, 255, 255, 0.28);
    border-bottom: 1px solid rgba(0, 0, 0, 0.18);
  }

  .ufa236-footer__social-inner,
  .ufa236-footer__bottom-inner {
    width: 100%;
    max-width: 1320px;
    margin: 0 auto;
  }

  .ufa236-footer__social-list {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: clamp(12px, 3vw, 26px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ufa236-footer__social-list li {
    margin: 0;
    padding: 0;
  }

  .ufa236-footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    color: var(--text-dark);
    background: rgba(255, 255, 255, 0.22);
    border: 1px solid var(--border-dark);
    border-radius: 8px;
    transition: transform 0.2s ease, background 0.2s ease, opacity 0.2s ease;
  }

  .ufa236-footer__social-link:hover,
  .ufa236-footer__social-link:focus {
    background: rgba(255, 255, 255, 0.36);
    transform: translateY(-2px);
    opacity: 0.9;
  }

  .ufa236-footer__social-link:focus-visible,
  .ufa236-footer__trust-link:focus-visible {
    outline: 2px solid var(--orange-light);
    outline-offset: 3px;
  }

  .ufa236-footer__social-icon {
    display: block;
    width: 21px;
    height: 21px;
    fill: currentColor;
  }

  /* BOTTOM BLACK BAR */
  .ufa236-footer__bottom {
    padding: 22px clamp(16px, 4vw, 72px);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.01)),
      linear-gradient(180deg, var(--dark-panel), var(--dark-soft), var(--dark));
    color: var(--text-light);
    border-top: 1px solid var(--border-light);
  }

  .ufa236-footer__bottom-inner {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(18px, 4vw, 48px);
  }

  .ufa236-footer__logo {
    display: inline-flex;
    align-items: center;
    min-width: 0;
  }

  .ufa236-footer__logo img {
    display: block;
    width: clamp(150px, 15vw, 230px);
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  .ufa236-footer__copy {
    margin: 0;
    color: var(--muted);
    font-size: clamp(13px, 1.15vw, 17px);
    font-weight: 600;
    line-height: 1.45;
    text-align: center;
  }

  .ufa236-footer__trust-list {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 12px clamp(18px, 3vw, 30px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ufa236-footer__trust-list li {
    margin: 0;
    padding: 0;
  }

  .ufa236-footer__trust-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    color: var(--text-light);
    font-size: clamp(13px, 1.1vw, 16px);
    font-weight: 700;
    line-height: 1.35;
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .ufa236-footer__trust-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 1px;
    height: 2px;
    border-radius: 99px;
    background: var(--orange);
    opacity: 0;
    transform: scaleX(0.4);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .ufa236-footer__trust-link:hover,
  .ufa236-footer__trust-link:focus {
    color: var(--orange-light);
  }

  .ufa236-footer__trust-link:hover::after,
  .ufa236-footer__trust-link:focus::after {
    opacity: 1;
    transform: scaleX(1);
  }

  @media (max-width: 900px) {
    .ufa236-footer__social-bar {
      padding: 16px 18px;
    }

    .ufa236-footer__bottom {
      padding: 24px 18px;
    }

    .ufa236-footer__bottom-inner {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: 16px;
      text-align: center;
    }

    .ufa236-footer__copy {
      text-align: center;
    }

    .ufa236-footer__trust-list {
      justify-content: center;
    }
  }

  @media (max-width: 520px) {
    .ufa236-footer__social-bar {
      padding: 14px 12px;
    }

    .ufa236-footer__social-list {
      gap: 8px;
    }

    .ufa236-footer__social-link {
      width: 34px;
      height: 34px;
      border-radius: 7px;
    }

    .ufa236-footer__social-icon {
      width: 19px;
      height: 19px;
    }

    .ufa236-footer__bottom {
      padding: 22px 14px;
    }

    .ufa236-footer__logo img {
      width: 150px;
    }

    .ufa236-footer__trust-list {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
      gap: 8px;
    }

    .ufa236-footer__trust-link {
      justify-content: center;
      width: 100%;
      min-height: 40px;
      padding: 8px 10px;
      border: 1px solid rgba(255, 173, 66, 0.22);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.06);
      font-size: 14px;
    }

    .ufa236-footer__trust-link::after {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ufa236-footer__social-link,
    .ufa236-footer__trust-link,
    .ufa236-footer__trust-link::after {
      transition: none;
    }
  }
</style>

