					<style>
  .ufa-bet-type-wrap {
    width: 100%;
    margin: 24px auto;
    font-family: inherit;
  }

  .ufa-bet-type-wrap,
  .ufa-bet-type-wrap * {
    box-sizing: border-box;
  }

  .ufa-bet-type-table {
    width: 100%;
    border-spacing: 0;
    border-collapse: separate;
    overflow: hidden;
    border: 1px solid rgba(255, 173, 66, 0.35);
    border-radius: 12px;
    background: #111111;
    color: #ffffff;
  }

  .ufa-bet-type-caption {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .ufa-bet-type-table th,
  .ufa-bet-type-table td {
    padding: 14px 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    vertical-align: middle;
    line-height: 1.55;
  }

  .ufa-bet-type-table th {
    background: linear-gradient(180deg, #ffd08a, #ffad42, #f28a18);
    color: #050505;
    font-size: 15px;
    font-weight: 800;
    text-align: left;
    white-space: nowrap;
  }

  .ufa-bet-type-table th:first-child {
    border-top-left-radius: 12px;
  }

  .ufa-bet-type-table th:last-child {
    border-top-right-radius: 12px;
  }

  .ufa-bet-type-table tbody tr:last-child td {
    border-bottom: 0;
  }

  .ufa-bet-type-table td {
    color: #eeeeee;
    font-size: 15px;
  }

  .ufa-bet-type-table tbody tr:nth-child(even) {
    background: rgba(255, 255, 255, 0.035);
  }

  .ufa-bet-type-table tbody tr:hover {
    background: rgba(255, 173, 66, 0.08);
  }

  .ufa-bet-type-table__type {
    color: #ffffff;
    font-weight: 800;
    white-space: nowrap;
  }

  .ufa-bet-type-table__risk {
    min-width: 120px;
    color: #ffcc33;
    font-size: 16px;
    letter-spacing: 1px;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .ufa-bet-type-table {
      border: 0;
      border-radius: 0;
      background: transparent;
    }

    .ufa-bet-type-table thead {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
    }

    .ufa-bet-type-table tbody,
    .ufa-bet-type-table tr,
    .ufa-bet-type-table td {
      display: block;
      width: 100%;
    }

    .ufa-bet-type-table tr {
      margin-bottom: 12px;
      overflow: hidden;
      border: 1px solid rgba(255, 173, 66, 0.28);
      border-radius: 12px;
      background: #111111;
    }

    .ufa-bet-type-table td {
      display: grid;
      grid-template-columns: 128px minmax(0, 1fr);
      gap: 10px;
      padding: 11px 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      font-size: 14px;
    }

    .ufa-bet-type-table td:last-child {
      border-bottom: 0;
    }

    .ufa-bet-type-table td::before {
      content: attr(data-label);
      color: #ffd08a;
      font-weight: 800;
    }

    .ufa-bet-type-table__type,
    .ufa-bet-type-table__risk {
      width: auto;
      min-width: 0;
      white-space: normal;
    }
  }

  @media (max-width: 380px) {
    .ufa-bet-type-table td {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
</style>

<section class="ufa-bet-type-wrap" aria-label="ตารางประเภทการเดิมพันฟุตบอล">
