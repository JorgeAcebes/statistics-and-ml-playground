        <td data-label="เหมาะกับผู้เล่น">ผู้ที่ติดตามเกมแบบเรียลไทม์</td>
        <td class="ufa-bet-type-table__risk" data-label="ระดับความเสี่ยง" aria-label="ความเสี่ยง 4 ดาว">★★★★☆</td>
      </tr>

